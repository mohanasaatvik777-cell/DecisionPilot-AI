PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ai-copilot
JWT_SECRET=your_super_secret_jwt_key_here

# AI providers actually used by the backend (utils/gemini.js, utils/openai.js).
# Note: @anthropic-ai/sdk is listed as a dependency but is NOT wired up anywhere
# in the code — do not rely on ANTHROPIC_API_KEY, it is currently unused.
GEMINI_API_KEY=AIza-your-gemini-key-here
OPENAI_API_KEY=sk-your-openai-key-here

CLIENT_URL=http://localhost:3000
NODE_ENV=development
